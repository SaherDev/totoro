# Application
app:
  environment: development
  port: 3333
  api_prefix: api/v1

# Data Access
database:
  url: postgresql://totoro:totoro_local@localhost:5432/totoro_dev?schema=public

# Authentication
auth:
  clerk:
    secret_key: sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Caching & Session
cache:
  redis:
    url: redis://localhost:6379

# AI Service Configuration
# enabled_default: Enables AI features for new users by default (boolean)
# global_kill_switch: Disables all AI features across the entire app (boolean)
ai:
  enabled_default: true
  global_kill_switch: false

# External Services & Integrations
integrations:
  slack:
    webhook_url: https://hooks.slack.com/services/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

# Feature Flags
features:
  enable_external_places: true
  enable_slack_alerts: false
